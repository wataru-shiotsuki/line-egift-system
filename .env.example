# LINE Messaging API
LINE_CHANNEL_SECRET=your_line_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LIFF_URL=https://liff.line.me/your-liff-id

# Google Gemini AI
GOOGLE_AI_API_KEY=your_gemini_api_key_here

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# App
PORT=3000
BASE_URL=https://your-ngrok-or-domain.com
ADMIN_USER=admin
ADMIN_PASS=password

# 社員への受け取り通知メール（Resend）
RESEND_API_KEY=re_...
NOTIFICATION_EMAIL=staff@example.com
# 任意：差出人（独自ドメイン検証後に変更可。未設定なら onboarding@resend.dev）
NOTIFICATION_FROM=Giftalk <onboarding@resend.dev>
